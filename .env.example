# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# These are only required for Aliyun MQTT (pre-2025 devices).
# Obtain the values from the Mammotion Android APK or from the maintainer.

ALIYUN_APP_KEY=
ALIYUN_APP_SECRET=

# MQTT poll cadence overrides (seconds).  Defaults match the built-in table.
# MAMMOTION_POLL_ACTIVE_SECS=900
# MAMMOTION_POLL_DOCKED_CHARGING_SECS=900
# MAMMOTION_POLL_DOCKED_FULL_SECS=3600
# MAMMOTION_POLL_IDLE_SECS=1800
